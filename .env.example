# LLM settings
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=your_groq_api_key

# GitHub Personal Access Token (for downloading repository PRs and issues)
GITHUB_TOKEN=your_github_personal_access_token

# API key for maintenance tasks (optional, used in api/routes/maintenance.py)
MAINTENANCE_API_KEY=your_maintenance_api_key
