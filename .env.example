# LLM Model Configuration
# Primary high-performance model (e.g. groq/llama-3.3-70b-versatile)
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY="your_groq_api_key_here"

# Vector Database and Embedding Configuration
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Cognee System Configuration
# API key to initialize Cognee database components (can be a standard random hex key)
COGNEE_API_KEY="your_cognee_api_key_here"

# GitHub Personal Access Token (for scraping issues and PR metadata)
GITHUB_TOKEN="your_github_personal_access_token_here"
